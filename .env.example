# TravManager Environment Configuration
# Copy this to .env and fill in values

# Database (Railway sets DATABASE_URL automatically — see config.py for auto-conversion)
DATABASE_URL=postgresql+asyncpg://travmanager:travmanager_dev_2024@db:5432/travmanager
DATABASE_URL_SYNC=postgresql://travmanager:travmanager_dev_2024@db:5432/travmanager
DB_PASSWORD=travmanager_dev_2024

# Redis (Railway sets REDIS_URL automatically)
REDIS_URL=redis://redis:6379/0

# Auth — CHANGE IN PRODUCTION!
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Application
APP_NAME=TravManager
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Game Settings
NPC_MIN_FIELD_SIZE=8
NPC_MAX_FIELD_SIZE=12
STARTING_BALANCE=20000000
